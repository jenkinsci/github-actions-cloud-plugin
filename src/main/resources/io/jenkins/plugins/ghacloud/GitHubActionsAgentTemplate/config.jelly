<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:st="jelly:stapler">

    <st:adjunct includes="io.jenkins.plugins.ghacloud.GitHubActionsAgentTemplate.config" />

    <f:entry title="${%Template Name}" field="templateName">
        <f:textbox clazz="required" />
    </f:entry>

    <f:entry title="${%Labels}" field="labelString">
        <f:textbox />
    </f:entry>

    <f:entry title="${%Remote FS Root}" field="remoteFs">
        <f:textbox default="/home/runner/agent" />
    </f:entry>

    <f:entry title="${%Number of Executors}" field="numExecutors">
        <f:number default="1" clazz="required positive-number" />
    </f:entry>

    <f:entry title="${%Git Ref}" field="gitRef">
        <f:textbox default="main" />
    </f:entry>

    <f:entry title="${%One-Shot Agent}" field="oneShot">
        <f:checkbox />
    </f:entry>

    <f:entry title="${%Idle Termination Minutes}" field="idleMinutes">
        <f:number default="5" clazz="required positive-number" />
    </f:entry>

    <f:entry title="${%Workflow File Name}" field="workflowFileName">
        <f:textbox clazz="required" placeholder="jenkins-agent.yml" />
    </f:entry>

    <f:entry title="${%Max Number of Agents}" field="maxAgents">
        <f:number default="0" min="0" />
    </f:entry>

    <f:entry>
        <div align="right">
            <f:repeatableDeleteButton />
        </div>
    </f:entry>

</j:jelly>
